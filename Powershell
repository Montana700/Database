$csvfile = "$PSScriptRoot\users.csv"
$domainname = "PurpleLab.local"

# Functie Add-ToLog

# Voor het wegschrijven van meldingen in een logboek

# Voorbeeld 1: Add-ToLog -Message "Gebruiker is aangemaakt in Active Directory"

function Add-ToLog(){
param (
[Parameter(Mandatory)]
[string]$Message # verplicht
)
$Path = "$PSScriptRoot\Log\ADUserlog.txt"
Try {
Add-Content -Path $Path -Value "$(Get-Date);$($env:computername);$($Message);$($[MyInvocation.MyCommand.Name](http://myinvocation.mycommand.name/))" -ErrorAction Stop
}
Catch{
Write-Error "Kan geen gegevens wegschrijven naar $Path ."
Start-Sleep 5
exit
}
}

